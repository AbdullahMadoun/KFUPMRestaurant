{
  "run": {
    "name": "trial-20260321-stability3",
    "notes": "3-epoch stability rerun after Stage3 full-checkpoint fix and no-NMS defaults",
    "tags": [
      "joint",
      "giou",
      "episodic"
    ]
  },
  "paths": {
    "images": "data/kfupm/images",
    "annotations": "data/kfupm/annotations.json",
    "splits": "data/kfupm/splits.json",
    "reference_library": "data/reference_library",
    "price_table": "data/prices.json",
    "checkpoints": "checkpoints",
    "outputs": "outputs",
    "logs": "logs"
  },
  "data": {
    "image_size": 640,
    "num_classes": 29,
    "num_workers": 8,
    "pin_memory": true,
    "integration": {
      "batch_root": "/root/dataset",
      "export_root": "",
      "repo_root": ".",
      "train_ratio": 0.8,
      "dev_ratio": 0.1,
      "val_ratio": 0.1,
      "test_ratio": 0.1,
      "split_seed": 420,
      "snapshot_export": false,
      "snapshot_dir": "snapshots/dataset",
      "stage1_prompt": "Locate and identify every food item on this plate. For each item, provide a JSON object with a 'box' key containing the [x1, y1, x2, y2] pixel coordinates. Return ONLY a valid JSON list of these objects."
    }
  },
  "hardware": {
    "device": "auto",
    "fp16": true,
    "bf16": true,
    "compile": true,
    "gradient_checkpointing": true,
    "load_in_4bit": false
  },
  "logging": {
    "wandb": true,
    "wandb_project": "trifoodnet",
    "jsonl": true,
    "log_system_metrics": true,
    "log_gpu_metrics": true,
    "log_every_n_steps": 10,
    "save_every_n_epochs": 1,
    "keep_last_n_ckpts": 3,
    "profiler": {
      "enabled": false,
      "wait_steps": 1,
      "warmup_steps": 1,
      "active_steps": 3,
      "repeat": 1
    }
  },
  "stage1": {
    "model_name": "Qwen/Qwen2.5-VL-3B-Instruct",
    "max_new_tokens": 512,
    "temperature": 0.0,
    "lora": {
      "enabled": true,
      "r": 16,
      "alpha": 32,
      "dropout": 0.05,
      "use_rslora": true,
      "target_modules": [
        "q_proj",
        "k_proj",
        "v_proj",
        "o_proj"
      ]
    },
    "training": {
      "epochs": 60,
      "batch_size": 1,
      "grad_accum_steps": 4,
      "learning_rate": 2e-05,
      "weight_decay": 0.0001,
      "warmup_ratio": 0.1,
      "lr_scheduler": "cosine",
      "max_grad_norm": 1.0
    },
    "loss": {
      "lambda_giou": 2.0,
      "lambda_ce": 0.5
    },
    "eval": {
      "iou_threshold": 0.5,
      "interval": 1
    }
  },
  "stage2": {
    "model_name": "facebook/sam3",
    "freeze": {
      "image_encoder": true,
      "prompt_encoder": true,
      "mask_decoder": false
    },
    "training": {
      "epochs": 10,
      "batch_size": 8,
      "grad_accum_steps": 4,
      "learning_rate": 5e-05,
      "weight_decay": 0.0001,
      "warmup_ratio": 0.05,
      "lr_scheduler": "cosine",
      "max_grad_norm": 1.0
    },
    "loss": {
      "bce_weight": 0.5,
      "dice_weight": 2.0
    },
    "nms": {
      "iou_threshold": 0.0,
      "score_threshold": 0.0
    },
    "eval": {
      "interval": 1
    }
  },
  "stage3": {
    "clip_model": "pictsure/pictsure-vit",
    "embed_dim": 512,
    "train_embedding": true,
    "lora": {
      "enabled": true,
      "r": 16,
      "alpha": 32,
      "dropout": 0.05,
      "target_modules": [
        "linear1",
        "linear2",
        "out_proj"
      ]
    },
    "transformer": {
      "num_layers": 4,
      "num_heads": 8,
      "ff_dim": 1024,
      "dropout": 0.1
    },
    "episode": {
      "n_way": 5,
      "k_shot": 5,
      "query_per_class": 1,
      "episodes_per_epoch": 1000
    },
    "training": {
      "epochs": 30,
      "episodes_per_step": 8,
      "learning_rate": 0.0001,
      "weight_decay": 0.0001,
      "warmup_ratio": 0.05,
      "lr_scheduler": "cosine",
      "max_grad_norm": 1.0,
      "label_smoothing": 0.1
    },
    "loss": {
      "name": "balanced_softmax",
      "logit_adjust_tau": 0.5
    },
    "reference_library": {
      "min_images_per_class": 1,
      "max_images_per_class": 5
    },
    "eval": {
      "n_way": 5,
      "k_shot": 5,
      "episodes": 600,
      "zero_shot_held_out": 5,
      "zero_shot_refs": [
        1,
        3,
        5
      ],
      "interval": 1
    }
  },
  "joint": {
    "training": {
      "epochs": 3,
      "batch_size": 1,
      "grad_accum_steps": 8,
      "max_batches_per_epoch": 0,
      "learning_rate": 5e-06,
      "weight_decay": 0.0001,
      "warmup_ratio": 0.05,
      "lr_scheduler": "cosine",
      "max_grad_norm": 0.3,
      "early_stopping": {
        "enabled": false,
        "monitor": "joint/combined",
        "mode": "max",
        "patience": 3,
        "min_delta": 0.0001,
        "min_epochs": 3
      }
    },
    "loss_weights": {
      "lambda1": 1.0,
      "lambda2": 0.5,
      "lambda3": 1.5
    },
    "curriculum": {
      "gt_boxes_epochs": 3
    },
    "eval": {
      "interval": 1
    }
  },
  "pictsure": {
    "clip_model": "openai/clip-vit-large-patch14",
    "batch_size": 64,
    "use_hnsw": true,
    "hnsw_ef": 200,
    "hnsw_M": 32,
    "temperature": 0.07,
    "top_k": 5,
    "index_path": "data/pictsure_index"
  },
  "official_pictsure": {
    "enabled": true,
    "model_id": "pictsure/pictsure-vit",
    "device": "auto",
    "use_torch_compile": false,
    "compile_mode": "default",
    "use_autocast": true,
    "autocast_dtype": "float16",
    "hf_token_env": "HF_TOKEN"
  },
  "inference": {
    "nms_iou_threshold": 0.5,
    "score_threshold": 0.5,
    "top_k_classes": 1,
    "target_latency_ms": 2000,
    "device": "cuda"
  },
  "benchmark": {
    "warmup_steps": 5,
    "measure_steps": 20,
    "trace_dir": "outputs/profiler"
  }
}