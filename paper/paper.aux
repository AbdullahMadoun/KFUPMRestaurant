\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Student inference pipeline. Stage 1 is a fine-tuned 7B VLM that emits bboxes only (class-agnostic). Stage 2 (SAM3, frozen) refines each box into a pixel-accurate mask. Stage 3 (DINOv2-large) maps the masked crop into embedding space and assigns the class of the most similar of $\sim $3{,}900 training-set reference embeddings. The teacher pipeline (\S  \ref {sec:dataengine}) has the same three stages at $\sim $10$\times $ scale, run once offline.}}{5}{figure.caption.13}\protected@file@percent }
\newlabel{fig:pipeline-student}{{5}{5}{Student inference pipeline. Stage 1 is a fine-tuned 7B VLM that emits bboxes only (class-agnostic). Stage 2 (SAM3, frozen) refines each box into a pixel-accurate mask. Stage 3 (DINOv2-large) maps the masked crop into embedding space and assigns the class of the most similar of $\sim $3{,}900 training-set reference embeddings. The teacher pipeline (\S \ref {sec:dataengine}) has the same three stages at $\sim $10$\times $ scale, run once offline}{figure.caption.13}{}}
