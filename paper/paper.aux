\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Dish-correct rate by ground-truth item count. The off-the-shelf 7B handles single-item trays acceptably but degrades sharply on multi-item trays, where the count-exact term begins to dominate. The distilled student maintains performance across cardinalities.}}{9}{figure.caption.26}\protected@file@percent }
\newlabel{fig:dish-by-card}{{8}{9}{Dish-correct rate by ground-truth item count. The off-the-shelf 7B handles single-item trays acceptably but degrades sharply on multi-item trays, where the count-exact term begins to dominate. The distilled student maintains performance across cardinalities}{figure.caption.26}{}}
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces Dish-correct rate by ground-truth item count. Distillation adds roughly the same $\sim $$47$\,pp boost on 1-item and 2-item trays, and recovers from total failure ($0\%$) to $28.6\%$ on the rare 3+~item bucket. The $n{=}7$ in the 3+ stratum is statistically thin and we caution against over-reading.}}{9}{table.caption.28}\protected@file@percent }
\newlabel{tab:by-cardinality}{{8}{9}{Dish-correct rate by ground-truth item count. Distillation adds roughly the same $\sim $$47$\,pp boost on 1-item and 2-item trays, and recovers from total failure ($0\%$) to $28.6\%$ on the rare 3+~item bucket. The $n{=}7$ in the 3+ stratum is statistically thin and we caution against over-reading}{table.caption.28}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.4}Count-error distribution}{9}{subsection.7.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Distribution of $|\mathcal  {P}| - |\mathcal  {G}|$ across the 596-image held-out set. The off-the-shelf 7B's distribution is \textbf  {[skewed]}; the distilled 7B's is more sharply peaked at zero.}}{10}{figure.caption.27}\protected@file@percent }
\newlabel{fig:count-err}{{9}{10}{Distribution of $|\mathcal {P}| - |\mathcal {G}|$ across the 596-image held-out set. The off-the-shelf 7B's distribution is \textbf {[skewed]}; the distilled 7B's is more sharply peaked at zero}{figure.caption.27}{}}
\@writefile{lot}{\contentsline {table}{\numberline {9}{\ignorespaces Detailed metric panel on the 596-image held-out set (dev~$\cup $~test, neither participated in gradient updates). Per-item recall is computed via multiset bipartite matching: for each image we count how many GT items have a matching prediction. Macro averages over images, micro over total GT items. Distillation closes the per-item gap by $+45$~pp.}}{10}{table.caption.29}\protected@file@percent }
\newlabel{tab:detail}{{9}{10}{Detailed metric panel on the 596-image held-out set (dev~$\cup $~test, neither participated in gradient updates). Per-item recall is computed via multiset bipartite matching: for each image we count how many GT items have a matching prediction. Macro averages over images, micro over total GT items. Distillation closes the per-item gap by $+45$~pp}{table.caption.29}{}}
